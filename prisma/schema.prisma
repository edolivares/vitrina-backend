datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  email     String    @unique
  password  String
  bio       String?   @db.Text
  avatarId  String?   @map("avatar_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  avatar   Media?    @relation("UserAvatar", fields: [avatarId], references: [id])
  posts    Post[]
  savedPosts SavedPost[]
  sentMsgs Message[] @relation("SentMessages")
  sellerChats Chat[] @relation("SellerChats")
  buyerChats Chat[] @relation("BuyerChats")
  uploads  Media[]   @relation("UploadedMedia")
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

enum PostStatus {
  /// Borrador en creación/edición. No visible al público. Cuenta para el límite de 5 borradores activos.
  DRAFT
  /// Publicación activa e inmediatamente visible en la tienda/galería pública.
  PUBLISHED
  /// Producto vendido. Visible para consultas históricas y chats, pero no disponible para compra.
  SOLD
  /// Publicación pausada temporalmente. Oculta al público, no cuenta para el límite de 5 borradores.
  ARCHIVED
}

enum PostCondition {
  NEW
  USED
}

model Post {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  cityId      Int        @map("city_id")
  title       String
  description String     @db.Text
  price       Decimal    @db.Decimal(12, 2)
  latitude    Decimal?   @db.Decimal(9, 6)
  longitude   Decimal?   @db.Decimal(9, 6)
  /// Estado actual del post. Ver enum PostStatus para reglas de negocio de cada estado.
  status      PostStatus @default(PUBLISHED)
  condition   PostCondition @default(USED)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  city     City        @relation(fields: [cityId], references: [id])
  media    PostMedia[]
  savedBy  SavedPost[]
  chats    Chat[]
  views    PostView[]

  @@map("posts")
}

model PostView {
  id            String   @id @default(uuid()) @db.Uuid
  postId        String   @map("post_id") @db.Uuid
  viewerId      String?  @map("viewer_id") @db.Uuid
  ipHash        String?  @map("ip_hash")
  userAgentHash String?  @map("user_agent_hash")
  viewedAt      DateTime @default(now()) @map("viewed_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, viewedAt])
  @@index([postId, viewerId, viewedAt])
  @@index([postId, ipHash, userAgentHash, viewedAt])
  @@map("post_views")
}

enum MediaContext {
  AVATAR
  POST
}

model Media {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  url       String
  path      String?
  context   MediaContext
  placeholder String?
  width     Int?
  height    Int?
  size      Int?
  mimeType  String?  @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")
  posts     PostMedia[]

  uploader User   @relation("UploadedMedia", fields: [userId], references: [id], onDelete: Cascade)
  usersAvatar User[] @relation("UserAvatar")

  @@map("media")
}

model PostMedia {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  mediaId   String   @map("media_id") @db.Uuid
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  post  Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([postId, mediaId])
  @@map("post_media")
}

model SavedPost {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("saved_posts")
}

model Chat {
  id               String   @id @default(uuid()) @db.Uuid
  postId           String   @map("post_id") @db.Uuid
  sellerId         String   @map("seller_id") @db.Uuid
  buyerId          String   @map("buyer_id") @db.Uuid
  lastMessage      String?  @map("last_message") @db.Text
  lastMessageAt    DateTime @default(now()) @map("last_message_at")
  buyerLastReadAt  DateTime @default(now()) @map("buyer_last_read_at")
  sellerLastReadAt DateTime @default(now()) @map("seller_last_read_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  post     Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  seller   User      @relation("SellerChats", fields: [sellerId], references: [id], onDelete: Cascade)
  buyer    User      @relation("BuyerChats", fields: [buyerId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([postId, buyerId])
  @@index([sellerId])
  @@index([buyerId])
  @@map("chats")
}

model Message {
  id        String   @id @default(uuid()) @db.Uuid
  chatId    String   @map("chat_id") @db.Uuid
  senderId  String   @map("sender_id") @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Region {
  id          Int    @id
  name        String
  shortName   String @map("short_name")
  romanNumber String @map("roman_number")
  cities      City[]

  @@map("regions")
}

model City {
  id               Int     @id
  regionId         Int     @map("region_id")
  name             String
  latitudeDefault  Decimal @map("latitude_default") @db.Decimal(9, 6)
  longitudeDefault Decimal @map("longitude_default") @db.Decimal(9, 6)
  posts            Post[]

  region Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@map("cities")
}
