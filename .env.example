# Puerto de la aplicacion
PORT=4000

# Origenes permitidos por CORS, separados por coma y sin slash final
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:4000,https://vitrina-web-sigma.vercel.app"

#RATE LIMITS
# Rutas publicas
RATE_LIMIT_PUBLIC_WINDOW_MINUTES=15
RATE_LIMIT_PUBLIC_MAX=300
# Rutas login
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15
RATE_LIMIT_LOGIN_MAX=10
# Rutas registro
RATE_LIMIT_REGISTER_WINDOW_MINUTES=60
RATE_LIMIT_REGISTER_MAX=5
# Rutas refresh token
RATE_LIMIT_REFRESH_WINDOW_MINUTES=15
RATE_LIMIT_REFRESH_MAX=60
# Rutas media
RATE_LIMIT_MEDIA_WINDOW_MINUTES=15
RATE_LIMIT_MEDIA_MAX=30
# Rutas privadas de usuario
RATE_LIMIT_PRIVATE_WRITE_WINDOW_MINUTES=15
RATE_LIMIT_PRIVATE_WRITE_MAX=60

# String de conexion con Connection Pooler (Transaction Connection) - Puerto 6543 en Supabase
# Formato: postgresql://user:password@host:puerto/db_name?schema=public
DATABASE_URL="postgresql://user:password@host:6543/db_name?schema=public"

# Conexion directa a PostgreSQL (Direct Connection) - Puerto 5432 en Supabase (Usado para migraciones)
DIRECT_URL="postgresql://user:password@host:5432/db_name?schema=public"

# Firma secreta para JSON Web Tokens (JWT)
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="tu_firma_secreta_jwt_aqui"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN_DAYS=14
REFRESH_TOKEN_COOKIE_NAME="refreshToken"
COOKIE_SECURE=false
COOKIE_SAME_SITE="lax"

# Storage
# Opciones:
# - local: guarda archivos en STORAGE_LOCAL_DIR y los sirve desde /storage.
# - s3: guarda archivos en un bucket S3/Supabase usando las credenciales S3_*.
STORAGE_STRATEGY=local

# Storage local
# Se usa solo cuando STORAGE_STRATEGY=local.
STORAGE_LOCAL_DIR="./storage"
STORAGE_BUCKET="media"
CDN_BASE_URL="http://localhost:4000/storage"

# Storage S3 compatible con Supabase
# Para usar S3:
# 1. Cambiar STORAGE_STRATEGY=s3
# 2. Mantener STORAGE_BUCKET con el nombre del bucket
# 3. Cambiar CDN_BASE_URL por la URL publica del bucket/CDN
# 4. Completar las credenciales S3
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="us-east-1"
S3_ENDPOINT=""

# Media
MEDIA_AVATAR_MAX_FILE_SIZE_MB=2
MEDIA_POST_MAX_FILE_SIZE_MB=10
MEDIA_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp,image/avif"

# Metrics
METRICS_VIEW_DEDUPE_WINDOW_MINUTES=60
# Secreto para hashear direcciones IP y User Agents en métricas de vistas
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
METRICS_HASH_SECRET="usar_un_valor_aleatorio_distinto_en_produccion"

# Pusher Channels
# El app id, secret y cluster viven solo en backend.
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
