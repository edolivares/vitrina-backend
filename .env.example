# Puerto de la aplicacion
PORT=4000

# String de conexion con Connection Pooler (Transaction Connection) - Puerto 6543 en Supabase
# Formato: postgresql://user:password@host:puerto/db_name?schema=public
DATABASE_URL="postgresql://user:password@host:6543/db_name?schema=public"

# Conexion directa a PostgreSQL (Direct Connection) - Puerto 5432 en Supabase (Usado para migraciones)
DIRECT_URL="postgresql://user:password@host:5432/db_name?schema=public"

# Firma secreta para JSON Web Tokens (JWT)
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="tu_firma_secreta_jwt_aqui"
